<!-- pages/detail/detail.wxml - 动态详情 -->

<!-- ══════════ 递归子评论模板 ══════════ -->
<template name="nested-child">
  <view class="c-child" wx:for="{{list}}" wx:key="id" wx:for-item="ch">
    <text class="c-child-name">{{ch.user__nickname}}</text>
    <text class="c-child-reply" wx:if="{{ch.reply__user__nickname}}"> 回复 </text>
    <text class="c-child-name" wx:if="{{ch.reply__user__nickname}}">{{ch.reply__user__nickname}}</text>
    <text class="c-child-colon">：</text>
    <text class="c-child-content">{{ch.content}}</text>
    <view class="c-child-actions">
      <text class="c-child-reply-btn" catchtap="onReply" data-id="{{ch.id}}" data-name="{{ch.user__nickname}}" data-root="{{rootId}}">回复</text>
      <text class="c-child-favor-btn {{ch._isFavor ? 'c-favored' : ''}}" catchtap="onToggleCommentFavor" data-id="{{ch.id}}">{{ch._isFavor ? '❤️' : '🤍'}} {{ch.favor_count||0}}</text>
    </view>
    <template wx:if="{{ch.children && ch.children.length > 0}}" is="nested-child" data="{{list: ch.children, rootId: rootId}}" />
  </view>
</template>

<view class="page-container" wx:if="{{!loading}}">

  <!-- ══════════ 用户头部 ══════════ -->
  <view class="d-header">
    <view class="d-avatar" style="background-color:{{detail._avatarBg}};">
      <text wx:if="{{!detail.user.avatar}}">{{detail._avatarChar}}</text>
      <image wx:else src="{{detail.user.avatar}}" mode="aspectFill" />
    </view>
    <view class="d-user-info">
      <text class="d-nickname">{{detail.user.nickname}}</text>
      <text class="d-time">{{detail.create_date}}</text>
    </view>
  </view>

  <!-- ══════════ 正文 ══════════ -->
  <view class="d-content" wx:if="{{detail.content}}">
    <text>{{detail.content}}</text>
  </view>

  <!-- ══════════ 图片轮播 ══════════ -->
  <view class="d-images" wx:if="{{detail.imageList && detail.imageList.length > 0}}">
    <swiper class="d-swiper" indicator-dots indicator-color="rgba(255,255,255,0.4)" indicator-active-color="#FFFFFF">
      <swiper-item wx:for="{{detail.imageList}}" wx:key="id">
        <image src="{{item.cos_path}}" mode="aspectFill" class="d-swiper-img" bindtap="onPreviewImage" data-src="{{item.cos_path}}" />
      </swiper-item>
    </swiper>
  </view>

  <!-- ══════════ 话题 / 位置 ══════════ -->
  <view class="d-topic" wx:if="{{detail.topic}}">
    <text class="d-topic-tag">{{detail.topic.title}}</text>
  </view>
  <view class="d-address" wx:if="{{detail.address}}">
    <text class="d-addr-text">📍 {{detail.address}}</text>
  </view>

  <!-- ══════════ 互动统计 ══════════ -->
  <view class="d-stats">
    <view class="d-stat d-stat-action {{isFavor ? 'stat-favored' : ''}}" bindtap="onToggleFavor">
      <text class="d-stat-icon">{{isFavor ? '❤️' : '🤍'}}</text>
      <text>{{favorCount||detail.favor_count||0}}</text>
    </view>
    <view class="d-stat">
      <text class="d-stat-icon">💬</text>
      <text>{{comment_count||detail.comment_count||0}}</text>
    </view>
    <view class="d-stat">
      <text class="d-stat-icon">👁</text>
      <text>{{detail.viewer_count||0}}</text>
    </view>
    <view class="d-stat d-stat-share">
      <button class="share-btn-native" open-type="share">
        <text class="d-stat-icon">🔗</text>
        <text>分享</text>
      </button>
    </view>
  </view>

  <!-- ══════════ 浏览记录 ══════════ -->
  <view class="d-section" wx:if="{{detail.viewer && detail.viewer.result.length > 0}}">
    <view class="d-section-title"><text>浏览记录（{{detail.viewer.queryset}}）</text></view>
    <scroll-view class="viewer-scroll" scroll-x enable-flex>
      <view class="viewer-inner">
        <view class="viewer-item" wx:for="{{detail.viewer.result}}" wx:key="id">
          <view class="viewer-avatar" style="background-color:#E0E0E0;">
            <text wx:if="{{!item.avatar}}">{{item.nickname[0]}}</text>
            <image wx:else src="{{item.avatar}}" mode="aspectFill" />
          </view>
          <text class="viewer-name">{{item.nickname}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- ══════════ 评论列表 ══════════ -->
  <view class="d-section">
    <view class="d-section-title"><text>全部评论（{{comment_count||detail.comment_count||0}}）</text></view>

    <view class="comment-empty" wx:if="{{commentTree.length === 0}}">
      <text>暂无评论，来说两句吧</text>
    </view>

    <block wx:for="{{commentTree}}" wx:key="id" wx:for-item="root">

      <!-- ══════ 根评论 ══════ -->
      <view class="comment-item">
        <view class="c-avatar" style="background-color:#E0E0E0;">
          <text wx:if="{{!root.user__avatar}}">{{root.user__nickname[0]}}</text>
          <image wx:else src="{{root.user__avatar}}" mode="aspectFill" />
        </view>
        <view class="c-body">
          <view class="c-meta">
            <text class="c-name">{{root.user__nickname}}</text>
            <text class="c-date">{{root.create_date}}</text>
          </view>
          <text class="c-content">{{root.content}}</text>
          <view class="c-actions">
            <text class="c-action" bindtap="onReply" data-id="{{root.id}}" data-name="{{root.user__nickname}}">回复</text>
            <text class="c-action c-action-favor {{root._isFavor ? 'c-favored' : ''}}" catchtap="onToggleCommentFavor" data-id="{{root.id}}">{{root._isFavor ? '❤️' : '🤍'}} {{root.favor_count||0}}</text>
          </view>

          <!-- ★ 子评论区 ★ -->
          <view class="c-children" wx:if="{{root.children && root.children.length > 0}}">
            <template is="nested-child" data="{{list: root.children, rootId: root.id}}" />

            <!-- 已加载全部 -->
            <view class="c-expand" wx:if="{{root._childMinId && root._childNomore}}">
              <text style="color:#CCCCCC;">— 已加载全部回复 —</text>
            </view>
            <!-- 加载更多 -->
            <view class="c-expand" wx:elif="{{root._childMinId && !root._childNomore}}" bindtap="onLoadMoreChildren" data-id="{{root.id}}">
              <text wx:if="{{root._childLoading}}">加载中...</text>
              <text wx:else>加载更多回复</text>
            </view>
          </view>

          <!-- ★ 展开 / 收起 / 加载中 ★ -->
          <view class="c-expand" bindtap="onExpandChildren" data-id="{{root.id}}">
            <text wx:if="{{root._childLoading}}">加载中...</text>
            <text wx:elif="{{root._expanded}}">收起回复</text>
            <text wx:else>查看回复</text>
          </view>
        </view>
      </view>

    </block>

    <!-- ★ 加载更多根评论 ★ -->
    <view class="load-more" wx:if="{{commentTree.length > 0}}">
      <text wx:if="{{rootLoading}}">加载中...</text>
      <text wx:elif="{{rootNomore}}">— 没有更多评论了 —</text>
      <text wx:else bindtap="onLoadMoreComments">加载更多评论</text>
    </view>
  </view>

  <view class="safe-bottom"></view>
</view>

<!-- ══════════ 底部评论输入栏 ══════════ -->
<view class="comment-bar" wx:if="{{!loading}}">
  <view class="comment-bar-top" wx:if="{{replyTo}}">
    <text class="reply-hint">回复 {{replyTo}}</text>
    <view class="reply-cancel" bindtap="onCancelReply"><text>✕</text></view>
  </view>
  <view class="comment-bar-row">
    <input
      class="comment-input {{isLoggedIn ? '' : 'input-disabled'}}"
      value="{{commentText}}"
      bindinput="onCommentInput"
      bindtap="onCommentTap"
      placeholder="{{isLoggedIn ? (replyTo ? '' : '说点什么...') : '登录后参与评论'}}"
      placeholder-class="comment-placeholder"
      confirm-type="send"
      bindconfirm="onPostComment"
      adjust-position="{{false}}"
      cursor-spacing="20"
      disabled="{{!isLoggedIn}}"
    />
    <view class="comment-send {{commentText && isLoggedIn ? 'send-active' : ''}}" bindtap="onPostComment">
      <text>发送</text>
    </view>
  </view>
</view>
