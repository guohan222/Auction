/** pages/detail/detail.wxss - 动态详情 **/

.page-container {
  min-height: 100vh; background-color: #F5F5F5;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* ══════════ 用户头部 ══════════ */
.d-header {
  display: flex; align-items: center;
  background-color: #FFFFFF; padding: 28rpx 30rpx;
}
.d-avatar {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; margin-right: 20rpx; overflow: hidden;
  font-size: 30rpx; color: #FFFFFF; font-weight: 600;
}
.d-avatar image { width: 100%; height: 100%; }
.d-user-info { display: flex; flex-direction: column; }
.d-nickname { font-size: 30rpx; color: #333333; font-weight: 500; margin-bottom: 6rpx; }
.d-time { font-size: 24rpx; color: #BBBBBB; }

/* ══════════ 正文 ══════════ */
.d-content { background-color: #FFFFFF; padding: 0 30rpx 30rpx; }
.d-content text { font-size: 32rpx; color: #333333; line-height: 1.8; }

/* ══════════ 图片轮播 ══════════ */
.d-images { background-color: #FFFFFF; padding: 0 30rpx 30rpx; }
.d-swiper { width: 100%; height: 600rpx; border-radius: 12rpx; overflow: hidden; }
.d-swiper-img { width: 100%; height: 100%; background-color: #F0F0F0; }

/* ══════════ 话题 / 位置 ══════════ */
.d-topic { background-color: #FFFFFF; padding: 0 30rpx 14rpx; }
.d-topic-tag { display: inline-block; font-size: 24rpx; color: #00B6B9; background-color: #F0FAFA; padding: 6rpx 18rpx; border-radius: 8rpx; }
.d-address { background-color: #FFFFFF; padding: 0 30rpx 20rpx; }
.d-addr-text { font-size: 24rpx; color: #999999; }

/* ══════════ 互动统计 ══════════ */
.d-stats {
  display: flex; align-items: center;
  margin: 20rpx 30rpx; background-color: #FFFFFF;
  border-radius: 16rpx; padding: 28rpx 40rpx; gap: 60rpx;
}
.d-stat { display: flex; align-items: center; font-size: 26rpx; color: #666666; }
.d-stat-icon { margin-right: 10rpx; font-size: 28rpx; }

/* ══════════ 通用区块 ══════════ */
.d-section {
  margin: 0 30rpx 20rpx; background-color: #FFFFFF;
  border-radius: 16rpx; padding: 30rpx;
}
.d-section-title { padding-bottom: 20rpx; }
.d-section-title text { font-size: 30rpx; font-weight: 600; color: #333333; }

/* ══════════ 浏览记录 ══════════ */
.viewer-scroll { width: 100%; white-space: nowrap; }
.viewer-inner { display: inline-flex; gap: 24rpx; }
.viewer-item { display: flex; flex-direction: column; align-items: center; flex-shrink: 0; }
.viewer-avatar {
  width: 80rpx; height: 80rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 10rpx; overflow: hidden;
  font-size: 26rpx; color: #FFFFFF; font-weight: 600;
}
.viewer-avatar image { width: 100%; height: 100%; }
.viewer-name { font-size: 22rpx; color: #999999; }

/* ══════════ 评论 ══════════ */
.comment-empty { text-align: center; padding: 40rpx 0; }
.comment-empty text { font-size: 26rpx; color: #BBBBBB; }

.comment-item { display: flex; padding: 24rpx 0; border-bottom: 1rpx solid #F8F8F8; }
.comment-item:last-child { border-bottom: none; }
.c-avatar {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; margin-right: 20rpx; overflow: hidden;
  font-size: 22rpx; color: #FFFFFF; font-weight: 600;
}
.c-avatar image { width: 100%; height: 100%; }
.c-body { flex: 1; }
.c-meta { display: flex; align-items: center; margin-bottom: 10rpx; }
.c-name { font-size: 26rpx; color: #576B95; margin-right: 16rpx; }
.c-date { font-size: 22rpx; color: #CCCCCC; }
.c-content { font-size: 28rpx; color: #333333; line-height: 1.6; display: block; margin-bottom: 12rpx; }
.c-actions { display: flex; gap: 32rpx; }
.c-action { font-size: 24rpx; color: #999999; }

/* 二级回复 */
.c-children {
  margin-top: 16rpx; padding: 16rpx 20rpx;
  background-color: #F8F8F8; border-radius: 8rpx;
}
.c-child { position: relative; padding: 8rpx 60rpx 8rpx 0; font-size: 26rpx; line-height: 1.6; }
.c-child-name { color: #576B95; }
.c-child-reply { color: #999999; }
.c-child-colon { color: #999999; }
.c-child-content { color: #333333; }
.c-child-reply-btn {
  position: absolute; right: 0; top: 8rpx;
  font-size: 22rpx; color: #999999;
}

/* 展开按钮 */
.c-expand {
  margin-top: 14rpx; padding: 12rpx 0;
  font-size: 24rpx; color: #576B95;
}

/* 二级回复按钮 */
.c-child { position: relative; padding: 8rpx 20rpx 8rpx 0; font-size: 26rpx; line-height: 1.6; }
.c-child-name { color: #576B95; }
.c-child-reply { color: #999999; }
.c-child-colon { color: #999999; }
.c-child-content { color: #333333; }
.c-child-reply-btn {
  font-size: 22rpx; color: #999999; margin-left: 12rpx;
}

/* ══════════ 底部评论栏 ══════════ */
.comment-bar {
  position: fixed; bottom: 0; left: 0; right: 0;
  background-color: #FFFFFF;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.04);
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}
.comment-bar-top {
  display: flex; align-items: center; justify-content: space-between;
  padding: 12rpx 30rpx 0;
}
.reply-hint { font-size: 24rpx; color: #999999; }
.reply-cancel {
  width: 36rpx; height: 36rpx; border-radius: 50%;
  background-color: #EEEEEE; display: flex; align-items: center; justify-content: center;
}
.reply-cancel text { font-size: 20rpx; color: #999999; }
.comment-bar-row {
  display: flex; align-items: center; padding: 16rpx 30rpx;
}
.comment-input {
  flex: 1; height: 72rpx; background-color: #F5F5F5;
  border-radius: 36rpx; padding: 0 28rpx; font-size: 28rpx; color: #333333;
}
.comment-placeholder { color: #BBBBBB; }
.comment-send {
  flex-shrink: 0; margin-left: 16rpx;
  padding: 0 24rpx; height: 72rpx;
  display: flex; align-items: center; justify-content: center;
  border-radius: 36rpx; background-color: #CCCCCC;
}
.comment-send text { font-size: 28rpx; color: #FFFFFF; }
.send-active { background-color: #00B6B9; }

/* 加载更多 */
.load-more { text-align: center; padding: 30rpx 0 10rpx; }
.load-more text { font-size: 26rpx; color: #576B95; }

.safe-bottom { height: 30rpx; }
