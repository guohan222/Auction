<!-- pages/index/index.wxml - 首页瀑布流 -->
<view class="page-container">

  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">搜索动态</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="feed-empty" wx:if="{{!loading && leftList.length === 0 && rightList.length === 0}}">
    <text class="empty-icon">📭</text>
    <text class="empty-text">暂无动态，去发布第一条吧</text>
  </view>

  <!-- 双列瀑布流 -->
  <view class="waterfall" wx:else>
    <view class="wf-col">
      <view class="wf-card" wx:for="{{leftList}}" wx:key="id" bindtap="onTapItem" data-id="{{item.id}}">
        <!-- 封面图 -->
        <view class="wf-cover" wx:if="{{item.cover}}">
          <image src="{{item.cover}}" mode="widthFix" lazy-load />
        </view>
        <!-- 正文 -->
        <view class="wf-body">
          <text class="wf-content" wx:if="{{item.content}}">{{item.content}}</text>
          <!-- 话题 -->
          <view class="wf-topic" wx:if="{{item.topic}}">
            <text class="wf-topic-tag">{{item.topic.title}}</text>
          </view>
          <!-- 底部 -->
          <view class="wf-footer">
            <view class="wf-user">
              <view class="wf-avatar" style="background-color:{{item._avatarBg}};">
                <text wx:if="{{!item.user.avatar}}">{{item._avatarChar}}</text>
                <image wx:else src="{{item.user.avatar}}" mode="aspectFill" />
              </view>
              <text class="wf-nickname">{{item.user.nickname}}</text>
            </view>
            <view class="wf-stats">
              <text class="wf-stat wf-stat-btn" catchtap="onToggleFavor" data-id="{{item.id}}">❤️{{item.favor_count||0}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
    <view class="wf-col">
      <view class="wf-card" wx:for="{{rightList}}" wx:key="id" bindtap="onTapItem" data-id="{{item.id}}">
        <view class="wf-cover" wx:if="{{item.cover}}">
          <image src="{{item.cover}}" mode="widthFix" lazy-load />
        </view>
        <view class="wf-body">
          <text class="wf-content" wx:if="{{item.content}}">{{item.content}}</text>
          <view class="wf-topic" wx:if="{{item.topic}}">
            <text class="wf-topic-tag">{{item.topic.title}}</text>
          </view>
          <view class="wf-footer">
            <view class="wf-user">
              <view class="wf-avatar" style="background-color:{{item._avatarBg}};">
                <text wx:if="{{!item.user.avatar}}">{{item._avatarChar}}</text>
                <image wx:else src="{{item.user.avatar}}" mode="aspectFill" />
              </view>
              <text class="wf-nickname">{{item.user.nickname}}</text>
            </view>
            <view class="wf-stats">
              <text class="wf-stat wf-stat-btn" catchtap="onToggleFavor" data-id="{{item.id}}">❤️{{item.favor_count||0}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部 -->
  <view class="feed-footer" wx:if="{{leftList.length > 0}}">
    <text wx:if="{{loadingMore}}">加载中...</text>
    <text wx:elif="{{nomore}}">— 没有更多了 —</text>
  </view>

</view>
