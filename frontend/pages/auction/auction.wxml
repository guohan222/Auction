<!-- pages/auction/auction.wxml - 拍卖页 -->
<view class="page-container">

  <!-- 顶部搜索栏 -->
  <view class="search-bar">
    <view class="search-input">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">搜索拍品</text>
    </view>
  </view>

  <!-- 轮播 Banner -->
  <view class="banner-wrap">
    <swiper class="banner-swiper" indicator-dots autoplay circular interval="4000">
      <swiper-item>
        <view class="banner-slide" style="background: linear-gradient(135deg, #4E3815, #B6915A);">
          <view class="banner-text">
            <text class="banner-title">典藏拍卖季</text>
            <text class="banner-sub">精选珍品 限时竞拍</text>
          </view>
        </view>
      </swiper-item>
      <swiper-item>
        <view class="banner-slide" style="background: linear-gradient(135deg, #1A3A4A, #2E7D8A);">
          <view class="banner-text">
            <text class="banner-title">新品首发</text>
            <text class="banner-sub">大师作品 独家呈现</text>
          </view>
        </view>
      </swiper-item>
      <swiper-item>
        <view class="banner-slide" style="background: linear-gradient(135deg, #5C1A2A, #B84560);">
          <view class="banner-text">
            <text class="banner-title">0元起拍</text>
            <text class="banner-sub">捡漏好物 每日更新</text>
          </view>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 分类快捷入口 -->
  <view class="category-entry">
    <view class="entry-item" wx:for="{{categories}}" wx:key="id">
      <view class="entry-icon" style="background-color: {{item.color}};">
        <text>{{item.icon}}</text>
      </view>
      <text class="entry-name">{{item.name}}</text>
    </view>
  </view>

  <!-- 正在拍卖标题 -->
  <view class="section-header">
    <view class="section-title-row">
      <view class="section-dot"></view>
      <text class="section-title">正在拍卖</text>
    </view>
    <text class="section-more">更多 ›</text>
  </view>

  <!-- 拍品列表 -->
  <view class="auction-list">
    <view class="auction-card" wx:for="{{auctionList}}" wx:key="id" bindtap="onTapItem" data-id="{{item.id}}">
      <view class="card-img" style="background-color: {{item.bgColor}};">
        <text class="card-img-text">{{item.name[0]}}</text>
      </view>
      <view class="card-info">
        <text class="card-name text-ellipsis">{{item.name}}</text>
        <view class="card-tags" wx:if="{{item.tags.length > 0}}">
          <text class="card-tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
        </view>
        <view class="card-price-row">
          <view class="card-price">
            <text class="price-label">当前价</text>
            <text class="price-value">¥{{item.currentPrice}}</text>
          </view>
          <view class="card-bid-count">
            <text>{{item.bidCount}}次出价</text>
          </view>
        </view>
        <view class="card-bottom">
          <text class="card-time">⏱ {{item.endTime}} 截拍</text>
        </view>
      </view>
    </view>
  </view>

  <view class="safe-bottom"></view>

</view>
