/** pages/auction/auction.wxss - 拍卖页样式 **/

.search-bar {
  padding: 20rpx 30rpx;
  background-color: #FFFFFF;
}
.search-input {
  display: flex; align-items: center;
  height: 72rpx; background-color: #F5F5F5;
  border-radius: 36rpx; padding: 0 30rpx;
}
.search-icon { font-size: 28rpx; margin-right: 12rpx; }
.search-placeholder { font-size: 28rpx; color: #999999; }

.banner-wrap { margin: 0 30rpx 24rpx; }
.banner-swiper { height: 280rpx; border-radius: 20rpx; overflow: hidden; }
.banner-slide { height: 100%; display: flex; align-items: center; padding: 0 50rpx; }
.banner-text { display: flex; flex-direction: column; }
.banner-title { font-size: 40rpx; font-weight: 700; color: #FFFFFF; margin-bottom: 12rpx; }
.banner-sub { font-size: 26rpx; color: rgba(255,255,255,0.85); }

.category-entry {
  display: flex; justify-content: space-around;
  padding: 16rpx 30rpx 24rpx; background-color: #FFFFFF; margin-bottom: 20rpx;
}
.entry-item { display: flex; flex-direction: column; align-items: center; }
.entry-icon {
  width: 88rpx; height: 88rpx; border-radius: 24rpx;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 12rpx; font-size: 36rpx;
}
.entry-name { font-size: 24rpx; color: #333333; }

.section-header { display: flex; align-items: center; justify-content: space-between; padding: 0 30rpx 20rpx; }
.section-title-row { display: flex; align-items: center; }
.section-dot { width: 8rpx; height: 28rpx; background-color: #00B6B9; border-radius: 4rpx; margin-right: 16rpx; }
.section-title { font-size: 32rpx; font-weight: 700; color: #333333; }
.section-more { font-size: 26rpx; color: #999999; }

.auction-list { padding: 0 30rpx; }
.auction-card {
  display: flex; background-color: #FFFFFF; border-radius: 16rpx;
  margin-bottom: 20rpx; padding: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}
.card-img {
  width: 200rpx; height: 200rpx; border-radius: 12rpx;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.card-img-text { font-size: 60rpx; font-weight: 700; color: rgba(255,255,255,0.5); }
.card-info { flex: 1; margin-left: 24rpx; display: flex; flex-direction: column; justify-content: space-between; }
.card-name { font-size: 30rpx; font-weight: 600; color: #333333; margin-bottom: 8rpx; }
.card-tags { display: flex; margin-bottom: 8rpx; }
.card-tag { font-size: 20rpx; color: #B6915A; background-color: #FDF6ED; padding: 4rpx 12rpx; border-radius: 6rpx; margin-right: 10rpx; }
.card-price-row { display: flex; align-items: flex-end; justify-content: space-between; }
.price-label { font-size: 22rpx; color: #999999; }
.price-value { font-size: 36rpx; font-weight: 700; color: #D34166; margin-left: 8rpx; }
.card-bid-count { font-size: 22rpx; color: #999999; }
.card-bottom { display: flex; align-items: center; }
.card-time { font-size: 22rpx; color: #00B6B9; }
.safe-bottom { height: 30rpx; }
