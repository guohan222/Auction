/** pages/mine/mine.wxss - 我的页面样式 **/

/* Teal 渐变头部 */
.mine-header {
  background: linear-gradient(180deg, #00BCC1 0%, #00B6B9 40%, #00AEB1 100%);
  padding: 50rpx 40rpx 36rpx;
}
.header-user-row {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}
.header-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: rgba(255,255,255,0.25);
  border: 4rpx solid rgba(255,255,255,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  flex-shrink: 0;
  margin-right: 28rpx;
  overflow: hidden;
}
.header-info {
  display: flex;
  flex-direction: column;
}
.header-nickname {
  font-size: 38rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 14rpx;
}
.header-tags {
  display: flex;
}
.header-tag {
  font-size: 22rpx;
  color: #FFFFFF;
  background-color: rgba(255,255,255,0.22);
  padding: 6rpx 18rpx;
  border-radius: 6rpx;
  margin-right: 14rpx;
}
.header-tag.vip {
  color: #FFE4A0;
  background-color: rgba(255,228,160,0.18);
}

/* 头部积分/等级 */
.header-extra {
  display: flex;
}
.extra-item {
  display: flex;
  flex-direction: column;
  margin-right: 60rpx;
}
.extra-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 6rpx;
}
.extra-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.75);
}

/* 数据统计 */
.stats-card {
  display: flex;
  align-items: center;
  margin: -20rpx 30rpx 20rpx;
  padding: 28rpx 0;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  position: relative;
  z-index: 2;
}
.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #333333;
  margin-bottom: 8rpx;
}
.stat-label {
  font-size: 24rpx;
  color: #999999;
}

/* 通用卡片区块 */
.section-card {
  margin: 0 30rpx 20rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
}
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}
.section-more {
  font-size: 26rpx;
  color: #999999;
}

/* 订单图标行 */
.order-icons {
  display: flex;
  justify-content: space-around;
}
.order-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.order-emoji {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}
.order-label {
  font-size: 22rpx;
  color: #666666;
}

/* 功能菜单 */
.menu-card {
  padding: 0 30rpx;
}
.menu-row {
  display: flex;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}
.menu-icon {
  font-size: 36rpx;
  margin-right: 24rpx;
}
.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}
.menu-right {
  display: flex;
  align-items: center;
}
.menu-arrow {
  font-size: 32rpx;
  color: #CCCCCC;
}
.menu-badge {
  min-width: 36rpx;
  height: 36rpx;
  line-height: 36rpx;
  text-align: center;
  background-color: #D34166;
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 18rpx;
  padding: 0 8rpx;
  margin-right: 10rpx;
}
