/** pages/topic/topic.wxss **/

.page-container {
  min-height: 100vh;
  background-color: #F5F5F5;
}

/* 空状态 */
.topic-empty {
  display: flex; flex-direction: column; align-items: center;
  padding-top: 200rpx;
}
.empty-icon { font-size: 100rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 28rpx; color: #BBBBBB; }

/* 列表 */
.topic-list {
  margin: 20rpx 30rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
}

.topic-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 36rpx 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}
.topic-item:last-child { border-bottom: none; }

.topic-left { display: flex; align-items: center; }
.topic-name { font-size: 30rpx; color: #333333; font-weight: 500; }

.topic-right { display: flex; align-items: center; }
.topic-count { font-size: 24rpx; color: #BBBBBB; margin-right: 16rpx; }
.topic-check { font-size: 30rpx; color: #00B6B9; font-weight: 700; }

.topic-selected { background-color: #F0FAFA; }
.topic-selected .topic-name { color: #00B6B9; }

/* 底部 */
.topic-footer { text-align: center; padding: 30rpx 0; }
.topic-footer text { font-size: 24rpx; color: #CCCCCC; }
