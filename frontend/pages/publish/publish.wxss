/** pages/publish/publish.wxss **/

.page-container {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* ══════════ 素材上传区 ══════════ */
.media-row {
  display: flex;
  margin: 24rpx 30rpx;
  gap: 20rpx;
}
.media-btn {
  flex: 1;
  height: 200rpx;
  border: 2rpx dashed #CCCCCC;
  border-radius: 16rpx;
  background-color: #FFFFFF;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}
.media-btn.full-width {
  flex: none;
  width: 100%;
}
.media-icon {
  font-size: 52rpx;
  margin-bottom: 8rpx;
}
.media-label {
  font-size: 26rpx;
  color: #999999;
}

/* ══════════ 图片预览 ══════════ */
.img-section {
  margin: 0 30rpx 20rpx;
}
.img-scroll {
  width: 100%;
  white-space: nowrap;
}
.img-inner {
  display: inline-flex;
  gap: 16rpx;
  padding: 4rpx 0;
}
.img-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
}
.img-thumb {
  width: 100%;
  height: 100%;
  background-color: #EEEEEE;
}

/* 上传中蒙层 */
.img-upload-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
}
.img-upload-text {
  font-size: 22rpx;
  color: #FFFFFF;
}

/* 删除按钮 */
.img-delete {
  position: absolute;
  top: 0;
  right: 0;
  width: 44rpx;
  height: 44rpx;
  background-color: rgba(0,0,0,0.55);
  border-radius: 0 12rpx 0 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
}
.img-delete text {
  font-size: 22rpx;
  color: #FFFFFF;
}

/* ══════════ 文案输入 ══════════ */
.textarea-wrap {
  margin: 0 30rpx 20rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx 30rpx 16rpx;
}
.textarea-input {
  width: 100%;
  min-height: 200rpx;
  font-size: 30rpx;
  color: #333333;
  line-height: 1.7;
}
.textarea-placeholder {
  color: #BBBBBB;
  font-size: 30rpx;
}
.textarea-count {
  text-align: right;
  font-size: 24rpx;
  color: #BBBBBB;
  padding-top: 10rpx;
}

/* ══════════ 拓展功能列表 ══════════ */
.feature-list {
  margin: 0 30rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 0 30rpx;
}
.feature-item {
  display: flex;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}
.feature-icon {
  font-size: 34rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  width: 44rpx;
  text-align: center;
}
.feature-title {
  font-size: 28rpx;
  color: #333333;
  flex-shrink: 0;
  margin-right: 16rpx;
}
.feature-hint {
  flex: 1;
  font-size: 24rpx;
  color: #BBBBBB;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.feature-arrow {
  font-size: 30rpx;
  color: #CCCCCC;
  margin-left: 8rpx;
  flex-shrink: 0;
}

/* ══════════ 底部发布 ══════════ */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #FFFFFF;
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.04);
}
.submit-btn {
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.submit-btn text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
}
.submit-active {
  background: linear-gradient(135deg, #00B6B9, #00D4D8);
}
.submit-disabled {
  background-color: #CCCCCC;
  opacity: 0.6;
}
